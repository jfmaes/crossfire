{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "rawText": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "newInsights": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questionsForPeer": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questionsForHuman": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposedSpecDelta": {
      "type": "string"
    },
    "milestoneReached": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "requirements_clarified",
            "architecture_selected",
            "implementation_plan_ready"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "implementationPlan": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "proposedQuestions": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "priority": {
                "type": "number"
              },
              "rationale": {
                "type": "string"
              }
            },
            "required": [
              "text",
              "priority",
              "rationale"
            ],
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "synthesizedQuestions": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "priority": {
                "type": "number"
              },
              "rationale": {
                "type": "string"
              }
            },
            "required": [
              "text",
              "priority",
              "rationale"
            ],
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "followUpQuestions": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "priority": {
                "type": "number"
              },
              "rationale": {
                "type": "string"
              }
            },
            "required": [
              "text",
              "priority",
              "rationale"
            ],
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "sufficientContext": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "walkthroughGaps": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "location": {
                "type": "string"
              },
              "issue": {
                "type": "string"
              },
              "fix": {
                "type": "string"
              }
            },
            "required": [
              "location",
              "issue",
              "fix"
            ],
            "additionalProperties": false
          }
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "rawText",
    "summary",
    "newInsights",
    "assumptions",
    "disagreements",
    "questionsForPeer",
    "questionsForHuman",
    "proposedSpecDelta",
    "milestoneReached",
    "implementationPlan",
    "proposedQuestions",
    "synthesizedQuestions",
    "followUpQuestions",
    "sufficientContext",
    "walkthroughGaps"
  ],
  "additionalProperties": false
}
